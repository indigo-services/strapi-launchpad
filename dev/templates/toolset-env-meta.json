{
  "description": "Tracked metadata for ignored local environment templates generated by yarn toolset:init.",
  "files": {
    ".env.local": {
      "purpose": "Local repo and AI provider overrides. Prefer user-level env vars for secrets."
    },
    ".env.easypanel.local": {
      "purpose": "Local Easypanel control-plane overrides."
    },
    ".env.production.local": {
      "purpose": "Local frontend and cross-service runtime overrides."
    }
  },
  "vars": [
    {
      "key": "GITHUB_REPOSITORY",
      "provider": "github",
      "scope": "global",
      "description": "Optional owner/repo override for scripts that need GitHub context.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "indigo-buildops/indigo-studio"
    },
    {
      "key": "GITHUB_TOKEN",
      "provider": "github",
      "scope": "global",
      "description": "Optional user-level GitHub token. Prefer Windows user-level env vars over writing secrets here.",
      "required": false,
      "sensitive": true,
      "targetFile": ".env.local",
      "placeholder": "replace-with-github-token"
    },
    {
      "key": "OPENAI_API_KEY",
      "provider": "openai",
      "scope": "global",
      "description": "Optional user-level token for OpenAI-powered tooling. Windows user-level env vars are honored by the loader.",
      "required": false,
      "sensitive": true,
      "targetFile": ".env.local",
      "placeholder": "replace-with-openai-api-key"
    },
    {
      "key": "ZAI_API_KEY",
      "provider": "zai",
      "scope": "global",
      "description": "Optional user-level Z.AI key. The Z.AI coding-helper CLI loads this into Claude Code.",
      "required": false,
      "sensitive": true,
      "targetFile": ".env.local",
      "placeholder": "replace-with-zai-api-key"
    },
    {
      "key": "ZAI_OPENAI_BASE_URL",
      "provider": "zai",
      "scope": "coding-plan",
      "description": "Z.AI Coding Plan OpenAI-compatible base URL; use this instead of the general API base URL.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "https://api.z.ai/api/coding/paas/v4"
    },
    {
      "key": "ZAI_OPENAI_MODEL",
      "provider": "zai",
      "scope": "coding-plan",
      "description": "Default Z.AI model choice for complex coding tasks.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "glm-5.1"
    },
    {
      "key": "ZAI_OPENAI_ROUTINE_MODEL",
      "provider": "zai",
      "scope": "coding-plan",
      "description": "Routine-task Z.AI model choice recommended for lower quota burn.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "glm-4.7"
    },
    {
      "key": "ZAI_OPENAI_TURBO_MODEL",
      "provider": "zai",
      "scope": "coding-plan",
      "description": "Z.AI GLM-5-Turbo model choice for tools that expose the turbo Coding Plan model.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "glm-5-turbo"
    },
    {
      "key": "ZAI_OPENAI_FAST_MODEL",
      "provider": "zai",
      "scope": "coding-plan",
      "description": "Lightweight Z.AI model choice for faster responses.",
      "required": false,
      "sensitive": false,
      "targetFile": ".env.local",
      "default": "glm-4.5-air"
    },
    {
      "key": "EASYPANEL_API",
      "provider": "easypanel",
      "scope": "control-plane",
      "description": "Easypanel API token for local deployment automation.",
      "required": true,
      "sensitive": true,
      "targetFile": ".env.easypanel.local",
      "placeholder": "replace-with-api-token"
    },
    {
      "key": "EASYPANEL_PROJECT_NAME",
      "provider": "easypanel",
      "scope": "control-plane",
      "description": "Easypanel project containing the Strapi service.",
      "required": true,
      "sensitive": false,
      "targetFile": ".env.easypanel.local",
      "default": "riostack"
    },
    {
      "key": "WEBSITE_URL",
      "provider": "vercel",
      "scope": "runtime",
      "description": "Public Vercel-hosted frontend URL.",
      "required": true,
      "sensitive": false,
      "targetFile": ".env.production.local",
      "default": "https://call-indigo.com"
    },
    {
      "key": "STRAPI_URL",
      "provider": "strapi",
      "scope": "runtime",
      "description": "Server-side Strapi URL used by scripts and runtime checks.",
      "required": true,
      "sensitive": false,
      "targetFile": ".env.production.local",
      "default": "https://studio.call-indigo.com"
    }
  ]
}
